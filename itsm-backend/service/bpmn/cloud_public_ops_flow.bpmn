<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_CloudOps" targetNamespace="http://bpmn.io/schema/bpmn" exporter="ITSM Platform" exporterVersion="1.0">
  <process id="cloud_public_ops" name="公有云资源运维流程" isExecutable="true" camunda:versionTag="1.0">
    <documentation>公有云（阿里云/腾讯云/AWS）资源申请、变更、释放等运维流程</documentation>

    <!-- 开始事件 -->
    <startEvent id="StartEvent_1" name="开始">
      <outgoing>Flow_1</outgoing>
    </startEvent>

    <!-- 用户提交申请 -->
    <userTask id="Task_Submit" name="提交云资源申请" camunda:assignee="${initiator}">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </userTask>

    <!-- 运维审批 -->
    <userTask id="Task_OpsApproval" name="运维工程师审批" camunda:assignee="ops_engineer">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </userTask>

    <!-- 经理审批 -->
    <exclusiveGateway id="Gateway_Manager" name="经理审批" default="Flow_5">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_4</outgoing>
      <outgoing>Flow_5</outgoing>
    </exclusiveGateway>

    <!-- 审批拒绝 -->
    <userTask id="Task_Reject" name="告知申请人">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_6</outgoing>
    </userTask>

    <!-- 执行资源申请 -->
    <userTask id="Task_Execute" name="执行云资源操作" camunda:assignee="ops_engineer">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_7</outgoing>
    </userTask>

    <!-- 安全审核（高风险操作） -->
    <userTask id="Task_SecurityReview" name="安全审核">
      <incoming>Flow_7</incoming>
      <outgoing>Flow_8</outgoing>
    </userTask>

    <!-- 验证结果 -->
    <userTask id="Task_Verify" name="验证与反馈" camunda:assignee="${initiator}">
      <incoming>Flow_8</ingoing>
      <outgoing>Flow_9</outgoing>
    </userTask>

    <!-- 结束 -->
    <endEvent id="EndEvent_1" name="结束">
      <incoming>Flow_6</incoming>
      <incoming>Flow_9</incoming>
    </endEvent>

    <!-- 连线 -->
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_Submit"/>
    <sequenceFlow id="Flow_2" sourceRef="Task_Submit" targetRef="Task_OpsApproval"/>
    <sequenceFlow id="Flow_3" sourceRef="Task_OpsApproval" targetRef="Gateway_Manager"/>
    <sequenceFlow id="Flow_4" sourceRef="Gateway_Manager" name="拒绝" targetRef="Task_Reject">
      <conditionExpression xsi:type="tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${approved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_5" sourceRef="Gateway_Manager" name="通过" targetRef="Task_Execute"/>
    <sequenceFlow id="Flow_6" sourceRef="Task_Reject" targetRef="EndEvent_1"/>
    <sequenceFlow id="Flow_7" sourceRef="Task_Execute" targetRef="Task_SecurityReview"/>
    <sequenceFlow id="Flow_8" sourceRef="Task_SecurityReview" targetRef="Task_Verify"/>
    <sequenceFlow id="Flow_9" sourceRef="Task_Verify" targetRef="EndEvent_1"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="cloud_public_ops">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="180" y="100" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Submit_di" bpmnElement="Task_Submit">
        <dc:Bounds x="260" y="78" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OpsApproval_di" bpmnElement="Task_OpsApproval">
        <dc:Bounds x="400" y="78" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Manager_di" bpmnElement="Gateway_Manager" isMarkerVisible="true">
        <dc:Bounds x="540" y="95" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Reject_di" bpmnElement="Task_Reject">
        <dc:Bounds x="630" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Execute_di" bpmnElement="Task_Execute">
        <dc:Bounds x="630" y="78" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SecurityReview_di" bpmnElement="Task_SecurityReview">
        <dc:Bounds x="770" y="78" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Verify_di" bpmnElement="Task_Verify">
        <dc:Bounds x="910" y="78" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1042" y="100" width="36" height="36"/>
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
