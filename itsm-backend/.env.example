# ITSM 环境配置
# ===========================================
# 开发环境：使用 trust 认证，无需设置密码
# 生产环境：请务必设置强密码！

# 数据库配置（必需）
DB_PASSWORD=StrongPassword123!  # 开发环境用，生产环境请修改为强密码

# JWT 密钥（必需）
JWT_SECRET=itsm-dev-jwt-secret-2024  # 生产环境请使用复杂的随机字符串

# ===========================================
# 生产环境建议使用随机生成器创建密码，例如：
# JWT_SECRET=$(openssl rand -base64 32)
# DB_PASSWORD=$(openssl rand -base64 16)
# ===========================================
