# ============================================
# ITSM Production Environment Configuration
# ============================================
# Copy this file to .env.prod and fill in ALL values:
#   cp .env.prod.example .env.prod
#
# SECURITY: Never commit .env.prod to version control.
#           All values marked [REQUIRED] must be set.
# ============================================

# --------------------------------------------
# Database [REQUIRED]
# --------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=itsm
DB_PASSWORD=                 # [REQUIRED] Use a strong password (32+ chars)
DB_NAME=itsm_prod
DB_SSLMODE=disable           # Enable "require" if PostgreSQL supports SSL

# --------------------------------------------
# Redis [REQUIRED]
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=              # [REQUIRED] Use a strong password
REDIS_DB=0

# --------------------------------------------
# JWT Authentication [REQUIRED]
# --------------------------------------------
JWT_SECRET=                  # [REQUIRED] Minimum 32 characters, use a random string
                              # Generate: openssl rand -base64 48
JWT_EXPIRE_TIME=86400        # Access token: 24 hours
JWT_REFRESH_EXPIRE_TIME=604800  # Refresh token: 7 days

# --------------------------------------------
# Admin Account
# --------------------------------------------
ADMIN_PASSWORD=              # [REQUIRED] Strong password for admin account

# --------------------------------------------
# Server Configuration
# --------------------------------------------
SERVER_PORT=8090
SERVER_ENV=production
GIN_MODE=release
DEPLOYMENT_MODE=saas       # private / saas / saas_msp
ITSM_AUTO_MIGRATE=false    # 生产常驻后端建议关闭，由 itsm-init 一次性执行
ITSM_AUTO_SEED=false       # 生产常驻后端建议关闭，由 itsm-init 一次性执行
LOG_LEVEL=error              # debug/info/warn/error
LOG_FORMAT=json              # json for structured logging in production
LOG_PATH=/app/logs

# --------------------------------------------
# MinIO Object Storage [REQUIRED]
# --------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=            # [REQUIRED] MinIO or S3 access key
MINIO_SECRET_KEY=            # [REQUIRED] MinIO or S3 secret key
MINIO_BUCKET=itsm-uploads
MINIO_USE_SSL=false

# --------------------------------------------
# LLM Configuration (AI Features)
# --------------------------------------------
LLM_PROVIDER=openai          # openai/azure/local/minimax
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=              # Required if LLM_PROVIDER=openai
OPENAI_BASE_URL=             # Optional: custom endpoint

# --------------------------------------------
# CORS Configuration
# --------------------------------------------
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# --------------------------------------------
# Email Notifications (SMTP)
# --------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# --------------------------------------------
# DingTalk Notifications
# --------------------------------------------
DINGTALK_WEBHOOK=

# --------------------------------------------
# WeCom Notifications
# --------------------------------------------
WECOM_WEBHOOK=

# --------------------------------------------
# Frontend Configuration
# --------------------------------------------
NEXT_PUBLIC_API_URL=/api
ITSM_BACKEND_URL=http://itsm-backend:8090
NEXT_PUBLIC_ENABLE_AI=true

# --------------------------------------------
# Monitoring
# --------------------------------------------
ENABLE_METRICS=true
GRAFANA_PASSWORD=            # [RECOMMENDED] Set a strong Grafana admin password

# --------------------------------------------
# Embeddings (Knowledge Base RAG)
# --------------------------------------------
EMBEDDING_PIPELINE_INTERVAL=15
EMBEDDING_BATCH_SIZE=50
EMBEDDING_FULL_PASS_SIZE=200

# --------------------------------------------
# SSL Configuration (for Nginx)
# --------------------------------------------
# SSL_CERT_PATH=/etc/nginx/certs/fullchain.pem
# SSL_KEY_PATH=/etc/nginx/certs/privkey.pem
