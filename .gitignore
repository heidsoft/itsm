*.png
!docs/images/*.png

# API keys and secrets
*apikey*
*secret*
*password*
*.key
credentials*

# Graphify output cache
graphify-out/cache/
.graphify_*

# AI tool configs (developer-specific, do not track)
.trae/
.codex/
.codex-loop/
.workbuddy/
.playwright-cli/

# Python / Test
# 注释：tests/ 目录本身需要被跟踪,只有 ephemeral 测试产物应该被忽略。
# 之前的全局忽略会导致 itm-backend/tests/rbac 等回归测试无法入仓。
itsm-backend/tests/**/test-results/
itsm-backend/tests/**/coverage/
itsm-backend/tests/**/tmp/
itsm-frontend/tests/e2e/venv/
itsm-backend/memory/venv/
itsm-backend/.pytest_cache/
itsm-backend/memory/*.md
itsm-backend/memory/*.sh
itsm-backend/memory/run_tests.sh

# Build binaries
itsm-backend/itsm
itsm-backend/itsm-backend
itsm-backend/server

# All deploy artifacts (binaries, builds, distributions)
deploy/
dist/
build-output/

# Pre-built binaries (any platform)
*.binary
itsm-*-linux-*
itsm-*-darwin-*
itsm-*-windows-*

# Python / Test
# 重复:见上,只允许 ephemeral 测试产物被忽略。
itsm-frontend/tests/e2e/venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Compiled binary (large file)
itsm-backend/main
easycloud
easycloud/*
itsm-rag
itsm-rag/*
itsm-skill
itsm-skill/*
# Binaries
itsm-backend/deploy/itsm-new
itsm-backend/deploy/itsm-new-linux

# Build artifacts
itsm-backend/itsm-backend
itsm-backend/deploy/itsm
itsm-backend/deploy/itsm-new*
itsm-backend/service.test
itsm-backend/logs/
itsm-frontend/.next/
itsm-frontend/tests/e2e/venv/
release/

# 防止再次误提交大文件/二进制
/itsm-agent/itsm-agent
/itsm-agent/itsm-agent-*
/ai-dev-agent/ai-dev-agent
graphify-out/

